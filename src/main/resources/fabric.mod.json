{
	"schemaVersion": 1,
	"id": "autocrystal",
	"version": "${version}",
	"name": "AutoCrystal",
	"description": "A minecraft mod that destroys any crystals nearby. (useful for CPVP)",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/autocrystal/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.example.autocrystal.AutoCrystal"
		],
		"client": [
			"com.example.autocrystal.client.AutoCrystalClient"
		]
	},
	"mixins": [
		"autocrystal.mixins.json",
		{
			"config": "autocrystal.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}
